# Foundry VTT credentials for Docker-based testing.
# Copy this to .env and fill in your values, or use .env.1password with `task setup:secrets`.

FOUNDRY_USERNAME=your-foundryvtt-username
FOUNDRY_PASSWORD=your-foundryvtt-password
FOUNDRY_LICENSE_KEY=AAAA-BBBB-CCCC-DDDD-EEEE-FFFF
FOUNDRY_ADMIN_KEY=your-admin-password
