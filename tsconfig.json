{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": false,
    "outDir": "dist",
    "rootDir": "src/module",
    "sourceMap": true,
    "noEmit": true,
    "typeRoots": ["./types"]
  },
  "include": ["src/module/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
